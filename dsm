#!/bin/bash

# ==============================================================================
# dsm - Dotfiles Script Manager
# ==============================================================================

VERSION="1.0.0"
# URL used to check for updates
DSM_RAW_URL="https://raw.githubusercontent.com/Armanoide/dms/refs/heads/main/dsm"

# Configuration
SOURCE_DIR="${DSM_SOURCE_DIR:-$HOME/dotfiles/scripts}"
TARGET_DIR="${DMS_TARGET_DIR:-/usr/local/bin}"

# Helper Functions

show_help() {
    echo "dsm - Dotfiles Script Manager (v$VERSION)"
    echo "Usage: dsm <command> [target]"
    echo ""
    echo "Commands:"
    echo "  install <script|all>    Install a specific script or all scripts"
    echo "  uninstall <script|all>  Uninstall a specific script or all scripts"
    echo "  update                  Update dsm to the latest version"
    echo "  version                 Show current version"
    echo ""
    echo "Examples:"
    echo "  dsm install nvim        # Symlinks ~/dotfiles/.../nvim to /usr/local/bin/nvim"
    echo "  dsm install all         # Symlinks all scripts in the bin directory"
    echo ""
    echo "Source directory: $SOURCE_DIR"
}

check_source_dir() {
    if [ ! -d "$SOURCE_DIR" ]; then
        echo "[-] Error: Source directory '$SOURCE_DIR' does not exist."
        echo "    Make sure your dotfiles are cloned, or set DSM_SOURCE_DIR."
        exit 1
    fi
}

# Core Logic

install_script() {
    local script_name=$1
    local source_file="$SOURCE_DIR/$script_name"
    local target_file="$TARGET_DIR/$script_name"

    if [ -f "$source_file" ]; then
        # Ensure the source script is executable
        chmod +x "$source_file"
        # Create a symbolic link (requires sudo for /usr/local/bin)
        sudo ln -sf "$source_file" "$target_file"
        echo "[+] Installed: $script_name -> $target_file"
    else
        echo "[-] Error: Script '$script_name' not found in $SOURCE_DIR"
    fi
}

uninstall_script() {
    local script_name=$1
    local target_file="$TARGET_DIR/$script_name"

    # Check if it's a symlink AND if it points to our dotfiles directory
    if [ -L "$target_file" ] && [ "$(readlink "$target_file")" == "$SOURCE_DIR/$script_name" ]; then
        sudo rm "$target_file"
        echo "[-] Uninstalled: $script_name"
    else
        echo "[!] Skipped: '$script_name' is not managed by dsm (or not installed)"
    fi
}

update_dsm() {
    echo "[*] Checking for updates..."
    local tmp_file=$(mktemp)
    
    # Download the latest version of the script quietly
    if ! curl -fsSL "$DSM_RAW_URL" -o "$tmp_file"; then
        echo "[-] Error: Failed to check for updates. Check your internet connection."
        rm -f "$tmp_file"
        exit 1
    fi

    # Extract the version string from the downloaded file
    local remote_version
    remote_version=$(grep -E "^VERSION=" "$tmp_file" | cut -d'"' -f2)

    if [ -z "$remote_version" ]; then
        echo "[-] Error: Could not parse remote version."
        rm -f "$tmp_file"
        exit 1
    fi

    if [ "$VERSION" != "$remote_version" ]; then
        echo "[*] Updating dsm from v$VERSION to v$remote_version..."
        sudo mv "$tmp_file" "/usr/local/bin/dsm"
        sudo chmod +x "/usr/local/bin/dsm"
        echo "[+] Update complete!"
    else
        echo "[+] dsm is already up to date (v$VERSION)."
        rm -f "$tmp_file"
    fi
}

# Main Routing

COMMAND=$1
TARGET=$2

case "$COMMAND" in
    install)
        check_source_dir
        if [ -z "$TARGET" ]; then
            echo "[-] Error: Missing target. Use 'dsm install <script>' or 'dsm install all'."
            exit 1
        fi
        
        if [ "$TARGET" == "all" ]; then
            echo "[*] Installing all scripts from $SOURCE_DIR..."
            for file in "$SOURCE_DIR"/*; do
                if [ -f "$file" ]; then
                    install_script "$(basename "$file")"
                fi
            done
        else
            install_script "$TARGET"
        fi
        ;;

    uninstall)
        check_source_dir
        if [ -z "$TARGET" ]; then
            echo "[-] Error: Missing target. Use 'dsm uninstall <script>' or 'dsm uninstall all'."
            exit 1
        fi

        if [ "$TARGET" == "all" ]; then
            echo "[*] Uninstalling all dsm scripts..."
            for file in "$SOURCE_DIR"/*; do
                if [ -f "$file" ]; then
                    uninstall_script "$(basename "$file")"
                fi
            done
        else
            uninstall_script "$TARGET"
        fi
        ;;

    update)
        update_dsm
        ;;

    version)
        echo "dsm version $VERSION"
        ;;

    *)
        show_help
        exit 1
        ;;
esac
